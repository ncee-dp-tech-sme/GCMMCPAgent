# Reference configuration for the GCM LangChain Agent.
# Do not store real secrets in this file.
# The architecture uses secure keyring-based storage for sensitive values.

GCM_URL=https://gcm.example.com:443/ibm/mcp/mcp
GCM_HOSTNAME=gcm.example.com
API_PORT=443
SSL_VERIFY=true

KEYCLOAK_PORT=443
REALM=master
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

USERNAME=your-username
PASSWORD=your-password

# LLM Provider Configuration
# Set LLM_PROVIDER to either "watsonx" or "openai"
LLM_PROVIDER=watsonx

# WatsonX Configuration (used when LLM_PROVIDER=watsonx)
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_API_KEY=your-watsonx-api-key
WATSONX_PROJECT_ID=your-project-id
WATSONX_MODEL=ibm/granite-3-8b-instruct

# OpenAI Configuration (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2048

DISCOVERY_MODE=false
TOOL_CACHE_TTL=3600

# Logging configuration
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_DIR=logs