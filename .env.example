# Reference configuration for the GCM LangChain Agent.
# Do not store real secrets in this file.
# The architecture uses secure keyring-based storage for sensitive values.

GCM_URL=https://gcm.example.com:443/ibm/mcp/mcp
GCM_HOSTNAME=gcm.example.com
API_PORT=443
SSL_VERIFY=true

KEYCLOAK_PORT=443
REALM=master
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

USERNAME=your-username
PASSWORD=your-password

LLM_PROVIDER=watsonx
LLM_API_KEY=your-watsonx-api-key
LLM_PROJECT_ID=your-project-id
LLM_MODEL=ibm/granite-3-8b-instruct

DISCOVERY_MODE=false
TOOL_CACHE_TTL=3600