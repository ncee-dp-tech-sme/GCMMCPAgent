# WatsonX Orchestrate API Configuration
# Made with Bob
# 2026-06-10 02:49 UTC - Example environment configuration

# ============================================================================
# GCM Server Configuration (REQUIRED)
# ============================================================================
GCM_URL=https://gcm.example.com:9443
GCM_HOSTNAME=gcm.example.com
USERNAME=admin
PASSWORD=your_password
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret

# ============================================================================
# Keycloak Configuration (REQUIRED)
# ============================================================================
KEYCLOAK_PORT=443
REALM=master

# ============================================================================
# LLM Provider Configuration (REQUIRED - Choose ONE)
# ============================================================================

# Option 1: WatsonX
LLM_PROVIDER=watsonx
LLM_WATSONX_API_KEY=your_watsonx_api_key
LLM_WATSONX_PROJECT_ID=your_project_id
WATSONX_MODEL=ibm/granite-13b-chat-v2
WATSONX_TEMPERATURE=0.1
WATSONX_MAX_TOKENS=4096
WATSONX_TOP_P=1.0
WATSONX_TOP_K=50
WATSONX_DECODING_METHOD=greedy

# Option 2: OpenAI (uncomment to use)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4
# OPENAI_TEMPERATURE=0.1
# OPENAI_MAX_TOKENS=4096

# ============================================================================
# Agent Configuration (OPTIONAL)
# ============================================================================
DISCOVERY_MODE=false
MAX_ITERATIONS=20

# ============================================================================
# Orchestrate API Configuration (OPTIONAL)
# ============================================================================
ORCHESTRATE_HOST=0.0.0.0
ORCHESTRATE_PORT=8000
ORCHESTRATE_CORS_ENABLED=true
ORCHESTRATE_CORS_ORIGINS=*
ORCHESTRATE_SESSION_TIMEOUT=3600
ORCHESTRATE_MAX_SESSIONS=100
ORCHESTRATE_MAX_WORKERS=4
ORCHESTRATE_REQUEST_TIMEOUT=300
ORCHESTRATE_LOG_LEVEL=INFO
ORCHESTRATE_LOG_FORMAT=json